# ─────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────
APP_NAME="CV Tiang Telkom Akses"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=Asia/Jakarta

# ─────────────────────────────────────────────────────────────
# ADMIN API
# ─────────────────────────────────────────────────────────────
# Protect all /admin/* routes — never expose this to the internet
ADMIN_API_KEY=change-me-to-a-strong-random-secret

# ─────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=tiang_cv
DB_USERNAME=tiang_user
DB_PASSWORD=change-me

# ─────────────────────────────────────────────────────────────
# REDIS (queue, cache, circuit-breaker, JWT anti-replay)
# ─────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─────────────────────────────────────────────────────────────
# QUEUE
# ─────────────────────────────────────────────────────────────
# Options: redis | rabbitmq | sqs
QUEUE_CONNECTION=redis
QUEUE_DEFAULT=default
QUEUE_DEAD_LETTER=dead-letter

# RabbitMQ (if QUEUE_CONNECTION=rabbitmq)
RABBITMQ_HOST=
RABBITMQ_PORT=5672
RABBITMQ_USER=
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=/

# SQS (if QUEUE_CONNECTION=sqs)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
SQS_QUEUE_URL=
SQS_DEAD_LETTER_URL=

# ─────────────────────────────────────────────────────────────
# SUPABASE MOCK DRIVER (dev/demo only — replaces Telkom External API)
# Set TELKOM_API_AUTH_DRIVER=supabase to activate
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_PHOTOS_TABLE=photos
# Also update ALLOWED_IMAGE_DOMAINS to include your Supabase storage domain:
# ALLOWED_IMAGE_DOMAINS=xxxx.supabase.co

# ─────────────────────────────────────────────────────────────
# JOB PROCESSING
# ─────────────────────────────────────────────────────────────
JOB_MAX_RETRIES=3
JOB_RETRY_DELAY_SECONDS=30
WORKER_CONCURRENCY=5

# ─────────────────────────────────────────────────────────────
# CLIENT AUTHENTICATION (Telkom → Service)
# ─────────────────────────────────────────────────────────────
# Options: local | telkom
CLIENT_AUTH_DRIVER=local

# local driver
CLIENT_JWT_SECRET=change-me-local-jwt-secret

# telkom driver (used when CLIENT_AUTH_DRIVER=telkom)
TELKOM_JWT_SECRET=
TELKOM_JWT_ALGORITHM=HS256
# For RS256:
TELKOM_JWT_PUBLIC_KEY_PATH=/run/secrets/telkom.pem
TELKOM_JWT_ISSUER=
TELKOM_JWT_AUDIENCE=
TELKOM_CLAIM_SUB=sub

# ─────────────────────────────────────────────────────────────
# TELKOM EXTERNAL API
# ─────────────────────────────────────────────────────────────
# Authentication driver for calling Telkom API
# Options: api_key | bearer | oauth2
TELKOM_API_AUTH_DRIVER=bearer
TELKOM_API_BASE_URL=https://api.telkom.co.id
TELKOM_API_PHOTO_ENDPOINT=/v1/photos
TELKOM_API_CALLBACK_ENABLED=false
TELKOM_API_CALLBACK_ENDPOINT=/v1/photos/{photo_id}/result
TELKOM_API_TIMEOUT=30
TELKOM_API_PHOTO_CATEGORY=tiang

# API Key driver
TELKOM_API_KEY=

# Bearer driver
TELKOM_API_BEARER_TOKEN=

# OAuth2 driver
TELKOM_API_OAUTH_TOKEN_URL=
TELKOM_API_OAUTH_CLIENT_ID=
TELKOM_API_OAUTH_CLIENT_SECRET=
TELKOM_API_OAUTH_SCOPE=

# SSRF protection — comma-separated list of allowed image CDN domains
ALLOWED_IMAGE_DOMAINS=cdn.telkom.co.id,assets.telkom.co.id

# ─────────────────────────────────────────────────────────────
# INTERNAL SERVICE JWT (Worker → Inference)
# ─────────────────────────────────────────────────────────────
SERVICE_JWT_SECRET=change-me-internal-service-jwt-secret
SERVICE_JWT_TTL_SECONDS=30
SERVICE_JWT_ISSUER=tiang-worker
SERVICE_JWT_AUDIENCE=tiang-inference

# ─────────────────────────────────────────────────────────────
# INFERENCE SERVICE
# ─────────────────────────────────────────────────────────────
INFERENCE_BASE_URL=http://inference:8000
INFERENCE_TIMEOUT=120

# ─────────────────────────────────────────────────────────────
# CIRCUIT BREAKER
# ─────────────────────────────────────────────────────────────
# Telkom API circuit breaker
CB_TELKOM_FAILURE_THRESHOLD=5
CB_TELKOM_COOLDOWN_SECONDS=300

# Inference service circuit breaker
CB_INFERENCE_FAILURE_THRESHOLD=3
CB_INFERENCE_COOLDOWN_SECONDS=120

# ─────────────────────────────────────────────────────────────
# RESULT STORAGE
# ─────────────────────────────────────────────────────────────
# Options: database | s3
STORAGE_DRIVER=database

# S3 (if STORAGE_DRIVER=s3)
AWS_BUCKET=
AWS_ENDPOINT=

# ─────────────────────────────────────────────────────────────
# NOTIFICATION
# ─────────────────────────────────────────────────────────────
# Options: null | webhook | slack
NOTIFIER_DRIVER=null

# Webhook notifier
NOTIFIER_WEBHOOK_URL=
NOTIFIER_WEBHOOK_SECRET=

# Slack notifier
NOTIFIER_SLACK_WEBHOOK_URL=
NOTIFIER_SLACK_CHANNEL=#alerts

# ─────────────────────────────────────────────────────────────
# SCHEDULER
# ─────────────────────────────────────────────────────────────
# Cron expression for automatic photo fetching (default: every day at 01:00)
FETCH_SCHEDULE="0 1 * * *"

# ─────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────
LOG_CHANNEL=stderr
LOG_LEVEL=info
LOG_DEPRECATIONS_CHANNEL=null

# ─────────────────────────────────────────────────────────────
# HORIZON
# ─────────────────────────────────────────────────────────────
HORIZON_PREFIX=horizon:
